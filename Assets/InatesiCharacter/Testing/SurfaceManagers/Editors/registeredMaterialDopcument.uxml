<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement style="flex-grow: 1; align-items: stretch; justify-content: flex-start;">
        <ui:DropdownField label="name" choices="1,2,3" name="dropdown" binding-path="_registeredTextures" />
        <uie:ObjectField label="texture" name="texture" type="UnityEngine.Texture2D, UnityEngine.CoreModule" />
        <uie:PropertyField binding-path="textureName" name="textureName" />
        <ui:VisualElement name="selected-texture" style="flex-grow: 1; width: 200px; height: 200px; background-image: none; background-color: rgb(0, 0, 0); align-self: center; display: none;" />
        <uie:PropertyField binding-path="textures" style="display: none;" />
    </ui:VisualElement>
</ui:UXML>
